{
  "manifest_version": 3,
  "name": "Liquid Newtab",
  "version": "1.2.7",
  "description": "A clean and elegant customizable new tab page.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "search",
    "favicon"
  ],
  "host_permissions": [
    "https://t1.gstatic.com/*",
    "https://icons.duckduckgo.com/*",
    "https://www.google.com/s2/*",
    "https://icon.horse/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
